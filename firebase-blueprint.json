{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "email": { "type": "string", "format": "email", "description": "User email address." },
        "displayName": { "type": "string", "description": "User's full name." },
        "photoURL": { "type": "string", "description": "URL to user's profile picture." },
        "role": { "type": "string", "enum": ["admin", "client"], "description": "User's access level." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "Property": {
      "title": "Property Listing",
      "description": "Details of a real estate property.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique property ID." },
        "title": { "type": "string", "description": "Property title." },
        "price": { "type": "string", "description": "Property price (formatted)." },
        "location": { "type": "string", "description": "Property location." },
        "type": { "type": "string", "description": "Property type (e.g., Villa, Penthouse)." },
        "image": { "type": "string", "description": "Main property image URL." },
        "description": { "type": "string", "description": "Detailed property description." },
        "amenities": { "type": "array", "items": { "type": "string" }, "description": "List of amenities." },
        "authorUid": { "type": "string", "description": "UID of the admin who listed the property." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the property was listed." }
      },
      "required": ["title", "price", "location", "type", "image", "authorUid"]
    },
    "Inquiry": {
      "title": "Property Inquiry",
      "description": "User inquiry about a property.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique inquiry ID." },
        "propertyId": { "type": "string", "description": "ID of the property being inquired about." },
        "propertyTitle": { "type": "string", "description": "Title of the property." },
        "userName": { "type": "string", "description": "Name of the user making the inquiry." },
        "userEmail": { "type": "string", "format": "email", "description": "Email of the user." },
        "message": { "type": "string", "description": "Inquiry message." },
        "status": { "type": "string", "enum": ["pending", "contacted", "closed"], "description": "Status of the inquiry." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the inquiry was made." }
      },
      "required": ["propertyId", "userName", "userEmail", "message", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/properties/{propertyId}": {
      "schema": "Property",
      "description": "Collection of property listings."
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of property inquiries."
    }
  }
}
